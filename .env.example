# Copy this file to .env and fill in values from your Supabase project.
# Get these from your Supabase project: Settings -> API.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# The UUID of your tree row in the `trees` table (created during first-time setup).
VITE_TREE_ID=00000000-0000-0000-0000-000000000000

# Optional: base path for deployment. Leave blank for root-domain hosting.
# For GitHub Pages at https://<user>.github.io/<repo>/ use "/<repo>/"
# VITE_BASE_PATH=/family-chart/
